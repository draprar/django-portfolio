# Core Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_ADMIN_URL=admin
# Optional comma-separated regex list for rare proxy redirect exemptions.
DJANGO_SECURE_REDIRECT_EXEMPT=

# Optional services
SENTRY_DSN=
REDIS_URL=

# Email / contact
DEFAULT_FROM_EMAIL=webmaster@localhost
BREVO_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Storage backend
# Local media by default. Set USE_S3=True only with complete S3/Supabase config.
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
SUPABASE_PROJECT_REF=
AWS_S3_REGION_NAME=

# Feature flags
FEATURE_CHATBOT_ENABLED=False
CHATBOT_MAX_INPUT_LENGTH=500
CHATBOT_RESPONSE_TIMEOUT_SECONDS=5.0
CHATBOT_UNANSWERED_MAX_ITEMS=10000
CHATBOT_UNANSWERED_CACHE_TTL_SECONDS=604800

# Testing
DJANGO_TESTING=False

